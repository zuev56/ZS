# .env
# Основные настройки инфраструктуры
# Копируйте этот файл как .env и меняйте значения под свои нужды
HOST_IP=192.168.1.104

# === Portainer ===
PORTAINER_VERSION=latest
PORTAINER_PORT_HTTP=9000
PORTAINER_PORT_HTTPS=9443

# === PostgreSQL ===
POSTGRES_VERSION=latest
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# === Kafka ===
KAFKA_VERSION=latest
KAFKA_PORT=9092
KAFKA_JMX_PORT=9101
KAFKA_BROKER_ID=1
KAFKA_REPLICATION_FACTOR=1
KAFKA_MIN_ISR=1
KAFKA_JMX_HOSTNAME=localhost

# === Kafka UI ===
KAFKA_UI_VERSION=latest
KAFKA_UI_PORT=9280
KAFKA_CLUSTER_NAME=raspberry_pi5

## === RabbitMQ ===
# RABBITMQ_VERSION=3-management-alpine # Версия с менеджмент плагином
# RABBITMQ_AMQP_PORT=5672
# RABBITMQ_MGMT_PORT=15672 # UI
# RABBITMQ_USER=admin
# RABBITMQ_PASSWORD=admin

# === node-exporter ===
NODE_EXPORTER_PORT=9100

# === cAdvisor ===
CADVISOR_PORT=8085

# === Prometheus ===
PROMETHEUS_VERSION=latest
PROMETHEUS_PORT=9090

# === Grafana ===
GRAFANA_VERSION=latest
GRAFANA_PORT=3000
GRAFANA_USER=zuev56
GRAFANA_PASSWORD=firstRunPassword
GRAFANA_PLUGINS=
